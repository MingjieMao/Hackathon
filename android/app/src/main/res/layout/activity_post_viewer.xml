<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/postViewerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/buttonBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:backgroundTint="@color/tab_bar_fill"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1.5dp"
            app:cornerRadius="999dp"
            android:text="@string/action_back"
            android:textAllCaps="false"
            android:textColor="@color/ink_primary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/buttonPostEdit"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_pill"
            android:contentDescription="@string/action_edit_post"
            android:padding="11dp"
            android:src="@drawable/ic_edit_24"
            android:visibility="gone"
            app:tint="@color/ink_primary" />

        <TextView
            android:id="@+id/textPostViewerMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_mode_pill"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="@color/nav_active"
            android:textStyle="bold"
            android:visibility="gone" />
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/postViewerScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/layoutPostViewerHeaderCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textPostViewerAuthorAvatar"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:textAppearance="?attr/textAppearanceTitleLarge"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/textPostViewerForum"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ink_secondary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textPostViewerMeta"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ink_secondary" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/buttonPostMenu"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center_vertical"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/action_report"
                        android:padding="8dp"
                        android:src="@drawable/ic_flag_outline_24" />
                </LinearLayout>

                <TextView
                    android:id="@+id/textPostViewerTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="@color/ink_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textPostViewerBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="4dp"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="@color/ink_secondary" />

                <ImageView
                    android:id="@+id/imagePostViewerAttachment"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:layout_marginTop="12dp"
                    android:adjustViewBounds="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/post_image_attachment"
                    android:scaleType="fitCenter"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/textPostViewerState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/ink_secondary"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_pill"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp">

                        <ImageButton
                            android:id="@+id/buttonPostUpvote"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:contentDescription="@string/action_upvote"
                            android:focusable="true"
                            android:padding="5dp"
                            android:src="@drawable/ic_vote_up_outline_24" />

                        <TextView
                            android:id="@+id/textPostViewerScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="12dp"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ink_primary"
                            android:textStyle="bold" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="8dp"
                            android:background="@color/surface_border" />

                        <ImageButton
                            android:id="@+id/buttonPostDownvote"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:background="@android:color/transparent"
                            android:clickable="true"
                            android:contentDescription="@string/action_downvote"
                            android:focusable="true"
                            android:padding="5dp"
                            android:src="@drawable/ic_vote_down_outline_24" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/buttonPostBookmark"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_pill"
                        android:clickable="true"
                        android:contentDescription="@string/action_bookmark"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="70dp"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="0dp"
                        android:paddingBottom="0dp">

                        <ImageView
                            android:id="@+id/imagePostBookmarkIcon"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:padding="5dp"
                            android:src="@drawable/ic_bookmark_24" />

                        <TextView
                            android:id="@+id/textPostViewerBookmarkCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ink_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/textPostViewerComments"
                        android:layout_width="wrap_content"
                        android:layout_height="42dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/bg_pill"
                        android:clickable="true"
                        android:contentDescription="@string/action_reply"
                        android:focusable="true"
                        android:gravity="center"
                        android:minWidth="70dp"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <ImageView
                            android:id="@+id/imagePostViewerCommentsIcon"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:padding="3dp"
                            android:src="@drawable/ic_comment_outline_24" />

                        <TextView
                            android:id="@+id/textPostViewerCommentsCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/ink_primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/textCommentsHeading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="@string/comments_heading"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/ink_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textCommentsEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/comments_empty"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/ink_secondary"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMessages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clipToPadding="false"
                android:paddingBottom="12dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
