<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background">

    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/page_background"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never" />

        <FrameLayout
            android:id="@+id/navShell"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_tab_bar"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:elevation="10dp"
            android:padding="6dp">

            <View
                android:id="@+id/navIndicator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:background="@drawable/bg_tab_indicator"
                android:elevation="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/tabChannels"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconChannels"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_channel_24" />

                    <TextView
                        android:id="@+id/labelChannels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/nav_channels"
                        android:textColor="@color/nav_inactive"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabNotifications"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconNotifications"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_bell_24" />

                    <TextView
                        android:id="@+id/labelNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/nav_notifications"
                        android:textColor="@color/nav_inactive"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tabYou"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconYou"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_user_24" />

                    <TextView
                        android:id="@+id/labelYou"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/nav_you"
                        android:textColor="@color/nav_inactive"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/surface"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textDrawerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/drawer_workspace_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/ink_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDrawerSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/drawer_workspace_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/ink_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/buttonDrawerHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/accent_strong"
                android:text="@string/drawer_home"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/buttonDrawerQueue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/warning_ink"
                android:text="@string/drawer_queue"
                android:textAllCaps="false"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/buttonDrawerMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/accent_soft"
                android:textAllCaps="false"
                android:textColor="@color/accent_on_soft" />

            <Button
                android:id="@+id/buttonDrawerDrafts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/surface_alt"
                android:text="@string/drawer_saved_drafts"
                android:textAllCaps="false"
                android:textColor="@color/ink_primary" />

            <Button
                android:id="@+id/buttonDrawerTeamSpace"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/surface_alt"
                android:text="@string/drawer_team_space"
                android:textAllCaps="false"
                android:textColor="@color/ink_primary" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/buttonDrawerSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/surface_alt"
            android:drawableStart="@drawable/ic_settings_24"
            android:drawablePadding="10dp"
            android:gravity="start|center_vertical"
            android:text="@string/drawer_settings"
            android:textAllCaps="false"
            android:textColor="@color/ink_primary" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
