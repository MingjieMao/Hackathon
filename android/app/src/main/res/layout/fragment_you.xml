<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonYouDrawer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/main_open_drawer"
                android:padding="12dp"
                android:src="@drawable/ic_menu_24" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/you_title"
                android:textAppearance="?attr/textAppearanceHeadlineMedium"
                android:textColor="@color/ink_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textYouSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/you_subtitle"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/ink_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textYouAvatar"
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:gravity="center"
                    android:text="C"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textYouNickname"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/ink_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textYouUid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/ink_secondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonEditAvatar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/accent_soft"
                    android:text="@string/drawer_change_avatar"
                    android:textAllCaps="false"
                    android:textColor="@color/accent_on_soft" />

                <Button
                    android:id="@+id/buttonEditNickname"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/accent_soft"
                    android:text="@string/action_edit_nickname"
                    android:textAllCaps="false"
                    android:textColor="@color/accent_on_soft" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/textYouMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/accent_on_soft"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textYouModeBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/you_mode_body"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/ink_secondary" />

            <Button
                android:id="@+id/buttonYouToggleMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/accent_strong"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/you_tools_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/ink_primary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/you_tools_body"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/ink_secondary" />

            <Button
                android:id="@+id/buttonYouQueue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/warning_ink"
                android:text="@string/drawer_queue"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
