<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:id="@+id/textNotificationsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/notifications_title"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textColor="@color/ink_primary"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textNotificationsSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/notifications_subtitle"
        android:textAppearance="?attr/textAppearanceBodyLarge"
        android:textColor="@color/ink_secondary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/notifications_placeholder_title"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/ink_primary"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/notifications_placeholder_body"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/ink_secondary" />
    </LinearLayout>

</LinearLayout>
