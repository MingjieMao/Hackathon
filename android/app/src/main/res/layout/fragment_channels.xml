<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/channelsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/buttonChannelsDrawer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/main_open_drawer"
                android:padding="12dp"
                android:src="@drawable/ic_menu_24" />

            <TextView
                android:id="@+id/textChannelsMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_pill"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/accent_on_soft"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textChannelsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/channels_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textColor="@color/ink_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textChannelsSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/ink_secondary" />

        <LinearLayout
            android:id="@+id/cardChannelsHighlight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/textChannelsHighlightTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/channels_highlight_title"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/ink_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textChannelsHighlightBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/channels_highlight_body"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/ink_secondary" />

            <Button
                android:id="@+id/buttonChannelsQueue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="@color/warning_ink"
                android:text="@string/action_open_queue"
                android:textAllCaps="false"
                android:textColor="@color/white" />
        </LinearLayout>

        <TextView
            android:id="@+id/textFeedHeading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/main_feed_heading"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/ink_primary"
            android:textStyle="bold" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPosts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="72dp" />
    </LinearLayout>

    <ImageButton
        android:id="@+id/buttonCreatePost"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_fab"
        android:contentDescription="@string/action_new_post"
        android:elevation="8dp"
        android:padding="15dp"
        android:src="@drawable/ic_add_24" />

</FrameLayout>
