<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/userProfileRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/buttonProfileBack"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:background="@drawable/bg_pill"
            android:gravity="center"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/action_back"
            android:textColor="@color/ink_primary"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textProfileAvatar"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/textProfileName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="@color/ink_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textProfileMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/ink_secondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/layoutProfileFollowing"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="false"
                    android:foreground="@null"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:stateListAnimator="@null">

                    <TextView
                        android:id="@+id/textProfileFollowingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/ink_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/you_following"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/ink_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutProfileFollowers"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="false"
                    android:foreground="@null"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:stateListAnimator="@null">

                    <TextView
                        android:id="@+id/textProfileFollowersCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/ink_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/you_followers"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/ink_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutProfileEngagement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:clickable="true"
                    android:focusable="false"
                    android:foreground="@null"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:stateListAnimator="@null">

                    <TextView
                        android:id="@+id/textProfileEngagementCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/ink_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/you_engagement"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="@color/ink_secondary" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/buttonProfileFollow"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:textAllCaps="false"
                android:textColor="@color/ink_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/tab_bar_fill"
                app:cornerRadius="14dp"
                app:strokeColor="@color/surface_border"
                app:strokeWidth="1.5dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/buttonProfileTabPosts"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text="@string/you_tab_posts"
                android:textAllCaps="false"
                android:textColor="@color/ink_primary"
                android:textSize="14sp"
                app:backgroundTint="@color/tab_bar_fill"
                app:cornerRadius="999dp"
                app:strokeColor="@color/surface_border"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/buttonProfileTabComments"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text="@string/you_tab_comments"
                android:textAllCaps="false"
                android:textColor="@color/ink_primary"
                android:textSize="14sp"
                app:backgroundTint="@color/tab_bar_fill"
                app:cornerRadius="999dp"
                app:strokeColor="@color/surface_border"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/buttonProfileTabSaved"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text="@string/you_tab_saved"
                android:textAllCaps="false"
                android:textColor="@color/ink_primary"
                android:textSize="14sp"
                app:backgroundTint="@color/tab_bar_fill"
                app:cornerRadius="999dp"
                app:strokeColor="@color/surface_border"
                app:strokeWidth="1dp" />

            <Button
                android:id="@+id/buttonProfileTabLiked"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:text="@string/you_tab_liked"
                android:textAllCaps="false"
                android:textColor="@color/ink_primary"
                android:textSize="14sp"
                app:backgroundTint="@color/tab_bar_fill"
                app:cornerRadius="999dp"
                app:strokeColor="@color/surface_border"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textProfileContentEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/you_posts_empty"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/ink_secondary"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerProfilePosts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never" />

        <LinearLayout
            android:id="@+id/layoutProfileComments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
