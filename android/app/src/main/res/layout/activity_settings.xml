<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="24dp"
    android:paddingEnd="22dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/buttonSettingsBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_pill"
            android:contentDescription="@string/action_back"
            android:padding="10dp"
            android:src="@drawable/ic_close_24"
            app:tint="@color/ink_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:text="@string/settings_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/ink_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/rowSettingsLanguage"
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_language_24"
                app:tint="@color/ink_secondary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:text="@string/settings_language"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/ink_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSettingsLanguageValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/ink_secondary" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_chevron_right_24"
                app:tint="@color/ink_secondary" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="72dp"
            android:background="@color/surface_border" />

        <LinearLayout
            android:id="@+id/rowSettingsTheme"
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_palette_24"
                app:tint="@color/ink_secondary" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:text="@string/settings_theme"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/ink_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSettingsThemeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/ink_secondary" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_chevron_right_24"
                app:tint="@color/ink_secondary" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSettingsAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/textSettingsMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_mode_pill"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="@color/nav_active"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonSettingsModerationQueue"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="@string/drawer_queue"
            android:textAllCaps="false"
            android:textColor="@color/ink_primary"
            android:textSize="15sp"
            app:backgroundTint="@color/tab_bar_fill"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_flag_outline_24"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/ink_primary"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="18dp">

        <Button
            android:id="@+id/buttonSettingsSwitchAccount"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/action_switch_account"
            android:textAllCaps="false"
            android:textColor="@color/ink_primary"
            android:textSize="15sp"
            app:backgroundTint="@color/tab_bar_fill"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_user_24"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/ink_primary"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1dp" />

        <Button
            android:id="@+id/buttonSettingsLogout"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:text="@string/action_logout"
            android:textAllCaps="false"
            android:textColor="@color/ink_primary"
            android:textSize="15sp"
            app:backgroundTint="@color/tab_bar_fill"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_logout_24"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconTint="@color/ink_primary"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1dp" />
    </LinearLayout>
</LinearLayout>
