<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/createPostRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="18dp"
    android:paddingEnd="24dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/buttonCancelPost"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="@string/action_cancel"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/ink_primary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/buttonPublishPost"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:backgroundTint="@color/accent_strong"
            android:enabled="false"
            android:minWidth="82dp"
            android:text="@string/action_publish"
            android:textAllCaps="false"
            android:textColor="@color/white" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textCreatePostAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:text="C"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <EditText
                android:id="@+id/inputPostTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="@string/compose_post_prompt"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4"
                android:minHeight="56dp"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/ink_primary"
                android:textColorHint="@color/ink_secondary" />

            <EditText
                android:id="@+id/inputPostBody"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="@string/dialog_post_body_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/ink_primary"
                android:textColorHint="@color/ink_tertiary" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="@string/compose_reply_scope"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/ink_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="↶  ↷"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/ink_tertiary" />
    </LinearLayout>

</LinearLayout>
