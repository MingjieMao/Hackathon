<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/createPostRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="18dp"
    android:paddingEnd="24dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/buttonCancelPost"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="@string/action_cancel"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/ink_primary" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/buttonPublishPost"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            app:backgroundTint="@color/tab_bar_fill"
            app:strokeColor="@color/surface_border"
            app:strokeWidth="1.5dp"
            app:cornerRadius="999dp"
            android:enabled="false"
            android:minWidth="82dp"
            android:text="@string/action_publish"
            android:textAllCaps="false"
            android:textColor="@color/ink_primary" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textCreatePostAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:text="C"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <EditText
                android:id="@+id/inputPostTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="@string/compose_post_prompt"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4"
                android:minHeight="56dp"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/ink_primary"
                android:textColorHint="@color/ink_secondary" />

            <EditText
                android:id="@+id/inputPostBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="@string/dialog_post_body_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:minHeight="140dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/ink_primary"
                android:textColorHint="@color/ink_tertiary" />

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <RadioGroup
                    android:id="@+id/radioPostCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioCategoryStudy"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:checked="true"
                        android:text="@string/category_study" />

                    <RadioButton
                        android:id="@+id/radioCategorySocial"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_social" />

                    <RadioButton
                        android:id="@+id/radioCategoryFinals"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_finals" />

                    <RadioButton
                        android:id="@+id/radioCategoryAi"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_ai" />

                    <RadioButton
                        android:id="@+id/radioCategoryCustom"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:text="@string/category_custom" />
                </RadioGroup>
            </HorizontalScrollView>

            <EditText
                android:id="@+id/inputPostCustomCategory"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_search_bar"
                android:hint="@string/category_custom_hint"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="@color/ink_primary"
                android:textColorHint="@color/ink_tertiary"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/buttonAddEmoji"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_reply_tool"
                    android:contentDescription="@string/action_add_emoji"
                    android:padding="10dp"
                    android:src="@drawable/ic_emoji_24"
                    android:tint="@color/ink_primary" />

                <ImageButton
                    android:id="@+id/buttonAddPostImage"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_reply_tool"
                    android:contentDescription="@string/action_add_image"
                    android:padding="10dp"
                    android:src="@drawable/ic_image_24"
                    android:tint="@color/ink_primary" />

                <ImageButton
                    android:id="@+id/buttonMentionFriend"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/bg_reply_tool"
                    android:contentDescription="@string/action_mention_friend"
                    android:padding="10dp"
                    android:src="@drawable/ic_at_24"
                    android:tint="@color/ink_primary" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imagePostPreview"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="8dp"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_card"
                android:contentDescription="@string/post_image_attachment"
                android:scaleType="fitCenter"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="@string/compose_reply_scope"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/ink_secondary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="↶  ↷"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/ink_tertiary" />
    </LinearLayout>

</LinearLayout>
