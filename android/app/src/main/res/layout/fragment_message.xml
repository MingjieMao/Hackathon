<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/messageRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <LinearLayout
        android:id="@+id/layoutMessageAvatarColumn"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:gravity="top|center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textMessageAvatar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:text="A"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <View
            android:id="@+id/viewMessageThreadLine"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1"
            android:background="@color/surface_border"
            android:visibility="gone" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textMessageAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleSmall"
                android:textColor="@color/ink_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textMessageTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/ink_secondary" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/buttonMessageMenu"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/action_report"
                android:padding="6dp"
                android:src="@drawable/ic_more_horiz_24" />
        </LinearLayout>

        <TextView
            android:id="@+id/textMessageState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/ink_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/textMessageContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/ink_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingTop="7dp"
                android:paddingEnd="10dp"
                android:paddingBottom="7dp">

                <TextView
                    android:id="@+id/buttonMessageUpvote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"
                    android:text="@string/action_upvote_symbol"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/ink_secondary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textMessageScore"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/ink_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/buttonMessageDownvote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="4dp"
                    android:text="@string/action_downvote_symbol"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/ink_secondary"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/buttonMessageReply"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_pill"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:text="@string/action_reply"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/ink_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
